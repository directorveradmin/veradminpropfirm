{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Veradmin",
  "version": "0.1.0",
  "identifier": "com.veradmin.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build:web",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Veradmin",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ]
  }
}
