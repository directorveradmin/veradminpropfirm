{
    "name":  "veradmin",
    "private":  true,
    "version":  "0.1.0",
    "type":  "module",
    "scripts":  {
                    "doctor":  "node ./scripts/doctor.mjs",
                    "dev:web":  "next dev",
                    "dev:desktop":  "cd src-tauri \u0026\u0026 tauri dev",
                    "lint":  "next lint",
                    "typecheck":  "tsc --noEmit",
                    "test":  "vitest run",
                    "test:watch":  "vitest",
                    "db:generate":  "drizzle-kit generate",
                    "db:migrate":  "tsx ./scripts/db/migrate.ts",
                    "db:seed:demo":  "tsx ./scripts/db/seed-demo.ts",
                    "db:seed:edge":  "tsx ./scripts/db/seed-edge.ts",
                    "dev:reset":  "bash ./scripts/reset-local-dev.sh",
                    "build:web":  "next build --webpack",
                    "build:desktop":  "cd src-tauri \u0026\u0026 tauri build",
                    "tree":  "bash ./scripts/print-repo-tree.sh",
                    "step12:verify":  "powershell -ExecutionPolicy Bypass -File .\\scripts\\step12\\verify-step12.ps1 -RepoRoot .",
                    "start:web:standalone":  "node .next/standalone/server.js",
                    "verify:standalone":  "powershell -ExecutionPolicy Bypass -File .\\scripts\\step13\\verify-standalone-server.ps1 -RepoRoot .",
                    "prepare:windows-sidecar":  "powershell -ExecutionPolicy Bypass -File .\\scripts\\step13\\prepare-windows-node-sidecar.ps1 -RepoRoot .",
                    "verify:windows-sidecar":  "powershell -ExecutionPolicy Bypass -File .\\scripts\\step13\\verify-windows-node-sidecar.ps1 -RepoRoot ."
                },
    "dependencies":  {
                         "better-sqlite3":  "12.8.0",
                         "drizzle-orm":  "0.45.2",
                         "next":  "16.2.2",
                         "react":  "19.2.4",
                         "react-dom":  "19.2.4",
                         "zod":  "4.3.6"
                     },
    "devDependencies":  {
                            "@types/better-sqlite3":  "7.6.13",
                            "@types/node":  "25.5.2",
                            "@types/react":  "19.2.14",
                            "@types/react-dom":  "19.2.3",
                            "drizzle-kit":  "0.31.10",
                            "tsx":  "4.21.0",
                            "typescript":  "6.0.2",
                            "vitest":  "4.1.4"
                        }
}
